{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kodevagt",
  "version": "0.1.0",
  "identifier": "com.kodevagt-frontend.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["kodevagt"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kodevagt — Code Review",
        "width": 1280,
        "height": 832,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
